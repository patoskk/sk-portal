# Base CENTRAL del portal (Supabase nuevo)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...        # pública, respeta RLS (frontend)
SUPABASE_SERVICE_ROLE_KEY=eyJ...            # SOLO backend (cron). Nunca exponer.

# Protege /api/cron/* (Vercel Cron manda este valor como Bearer)
CRON_SECRET=pon-un-secreto-largo-aleatorio

# (Opcional para Claude insights) — ver app/api/cron/insights
ANTHROPIC_API_KEY=sk-ant-...

# Piloto: key de LECTURA del Supabase de cada cliente, por client_id.
# Reemplazar los guiones del uuid por guiones bajos y en MAYÚSCULAS.
# Ej. cliente 1a2b... -> SOURCE_KEY_1A2B...  (en producción usar Supabase Vault)
# SOURCE_KEY_<CLIENT_ID>=eyJ...
